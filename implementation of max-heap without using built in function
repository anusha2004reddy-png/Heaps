class maxHeap:

    def __init__(self):
        self.arr = []
        self.cnt = 0
        
    def heapifyDown(self,arr,ind):
        largest = ind
        lchild = 2*ind+1
        rchild = 2*ind+2
        if(lchild<len(arr) and arr[lchild]>arr[largest]):
            largest = lchild
        if(rchild<len(arr) and arr[rchild]>arr[largest]):
            largest = rchild
        if(largest!=ind):
            arr[ind],arr[largest] = arr[largest],arr[ind]
            self.heapifyDown(arr,largest)

            
    def heapifyUp(self,arr,ind):
        if(ind>0):
            parent = (ind-1)//2
            if(arr[parent]<arr[ind]):
                arr[ind],arr[parent] = arr[parent],arr[ind]
                self.heapifyUp(arr,parent)
    

    # Insert x into the heap
    def push(self, x: int):
        self.arr.append(x)
        self.heapifyUp(self.arr,self.cnt)
        self.cnt+=1


    # Remove the top (maximum) element
    def pop(self):
        self.arr[0],self.arr[self.cnt-1] = self.arr[self.cnt-1],self.arr[0]
        self.arr.pop()
        self.heapifyDown(self.arr,0)
        self.cnt-=1


    # Return the top element or -1 if empty
    def peek(self) -> int:
        if(self.cnt == 0):
            return -1
        return self.arr[0]


    # Return the number of elements in the heap
    def size(self) -> int:
        return self.cnt
